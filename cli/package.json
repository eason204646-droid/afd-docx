{
  "name": "afd-cli",
  "version": "0.1.2",
  "description": "AFD (Agent First Document) CLI — AI-native document format toolchain",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eason204646-droid/afd-docx.git",
    "directory": "cli"
  },
  "homepage": "https://github.com/eason204646-droid/afd-docx#readme",
  "bugs": {
    "url": "https://github.com/eason204646-droid/afd-docx/issues"
  },
  "keywords": ["afd", "document", "docx", "word", "cli"],
  "type": "module",
  "bin": {
    "afd": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "docx": "^8.5.0",
    "mammoth": "^1.8.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.61.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
